<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="FamilyMoney.Android.App"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:local="using:FamilyMoney"
             RequestedThemeVariant="Default">
  <Application.DataTemplates>
    <local:ViewLocator/>
  </Application.DataTemplates>

  <Application.Resources>
    <ResourceDictionary>
      <ResourceDictionary.MergedDictionaries>
        <ResourceInclude Source="avares://FamilyMoney.Navigation/Themes/AppThemeResources.axaml" />
      </ResourceDictionary.MergedDictionaries>
    </ResourceDictionary>
  </Application.Resources>

  <Application.Styles>
    <StyleInclude Source="avares://FamilyMoney.Navigation/Themes/FluentPalettes.axaml" />
    <StyleInclude Source="avares://FamilyMoney.Navigation/Themes/AppThemeStyles.axaml" />
    <mi:MaterialIconStyles />
  </Application.Styles>
</Application>
