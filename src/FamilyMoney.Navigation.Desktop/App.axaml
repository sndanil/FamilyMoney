<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:nav="using:FamilyMoney.Navigation"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             x:Class="FamilyMoney.Navigation.Desktop.App"
             RequestedThemeVariant="Default">

    <Application.DataTemplates>
        <nav:ViewLocator/>
    </Application.DataTemplates>

    <Application.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceInclude Source="avares://FamilyMoney.Navigation/Themes/AppThemeResources.axaml" />
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Application.Resources>

    <Application.Styles>
        <StyleInclude Source="avares://FamilyMoney.Navigation/Themes/FluentPalettes.axaml" />
        <StyleInclude Source="avares://FamilyMoney.Navigation/Themes/AppThemeStyles.axaml" />
        <mi:MaterialIconStyles />
    </Application.Styles>
</Application>
