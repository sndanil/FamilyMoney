<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="260"
        x:Class="FamilyMoney.DatabaseWindow"
        Width="600" Height="260"
		WindowStartupLocation="CenterOwner"
		ExtendClientAreaToDecorationsHint="True"
		ExtendClientAreaChromeHints="NoChrome"
		xmlns:views="clr-namespace:FamilyMoney.Views"
		xmlns:vm="clr-namespace:FamilyMoney.ViewModels.Settings"
		x:DataType="vm:DatabaseViewModel"		
		Classes="Dialog"
        Title="">
	<Window.Styles>
		<Style Selector="TextBox">
			<Setter Property="Margin" Value="4" />
			<Setter Property="HorizontalAlignment" Value="Stretch" />
		</Style>
		<Style Selector="NumericUpDown">
			<Setter Property="Margin" Value="4" />
		</Style>
	</Window.Styles>
	<Grid RowDefinitions="auto auto auto auto auto" ColumnDefinitions="* 20" Margin="5 50 5 5">
		<TextBox Text="{Binding Name}" Watermark="Наименование"/>
		<TextBox Grid.Row="1" Text="{Binding Path}" Watermark="Путь"/>
		<Button Grid.Row="1" Grid.Column="1"
				Classes="DialogToolButton"
				Content="..."
				/>

		<TextBox Grid.Row="2" Text="{Binding BackupsFolder}" Watermark="Папка для резервных копий"/>
		<Button Grid.Row="2" Grid.Column="1"
				Classes="DialogToolButton"
				Content="..."
				/>

		<NumericUpDown Grid.Row="3"
						Watermark="Максимум резервных копий"
						FormatString="#,##0"
						Value="{Binding MaxBackups}"
						/>
		<StackPanel
			Grid.Row="4"
			Grid.ColumnSpan="2"
			Orientation="Horizontal"
			HorizontalAlignment="Right"
			Margin="0 5 0 10"
			>
			<Button IsDefault="True" Classes="DialogButton" Content="OK" Command="{Binding OkCommand}" CommandParameter="{Binding}" />
			<Button IsCancel="True" Classes="DialogButton" Content="Отмена" Command="{Binding CancelCommand}"/>
		</StackPanel>
	</Grid>
</Window>
