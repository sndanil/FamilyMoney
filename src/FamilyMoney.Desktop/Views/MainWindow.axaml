<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
		xmlns:services="clr-namespace:FamilyMoney.Services;assembly=FamilyMoney"
        xmlns:vm="using:FamilyMoney.ViewModels"
		xmlns:settingsVm="using:FamilyMoney.ViewModels.Settings"
		xmlns:cv="using:FamilyMoney.Converters"
		xmlns:views="clr-namespace:FamilyMoney.Views"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="450"
		xmlns:i="clr-namespace:Avalonia.Xaml.Interactivity;assembly=Avalonia.Xaml.Interactivity"
		xmlns:ia="clr-namespace:Avalonia.Xaml.Interactions.Core;assembly=Avalonia.Xaml.Interactions"
        x:Class="FamilyMoney.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        Icon="/Assets/wallet.ico"
		WindowState="Maximized"
        Title="{Binding Title}">

	<Design.DataContext>
		<vm:MainViewModel/>
	</Design.DataContext>
	<Window.Resources>
		<cv:GridLengthConverter x:Key="gridLengthConverter" />
		<cv:IsEqualToConverter x:Key="isEqualToConverter" />
		<cv:IsNotEqualToConverter x:Key="isNotEqualToConverter" />
	</Window.Resources>
	<Window.Styles>
		<Style Selector="Window">
			<Setter Property="Background" Value="{DynamicResource MainBackBrush}" />
		</Style>
		<Style Selector="StackPanel.SideBarMenu">
			<Setter Property="Orientation" Value="Vertical"/>
			<Setter Property="Margin" Value="0" />
		</Style>
		<Style Selector="Border.SideBarMenuItem">
			<Setter Property="Background" Value="Transparent" />
		</Style>
		<Style Selector="Border.SideBarMenuItem StackPanel">
			<Setter Property="Orientation" Value="Horizontal"/>
			<Setter Property="Spacing" Value="17"/>
			<Setter Property="Margin" Value="15 10" />
		</Style>
		<Style Selector="Border.SideBarMenuItem:pointerover">
			<Setter Property="Background" Value="{DynamicResource HoverBackBrush}" />
		</Style>
		<Style Selector="Border.SideBarMenuItem:disabled">
			<Setter Property="Background" Value="{DynamicResource SelectedBackBrush}" />
		</Style>
		<Style Selector="Border.SideBarMenuItem mi|MaterialIcon">
			<Setter Property="Width" Value="14"/>
		</Style>
		<Style Selector="Button.AddButton">
			<Setter Property="Margin" Value="20 0 0 0" />
			<Setter Property="Height" Value="30" />
			<Setter Property="VerticalAlignment" Value="Center" />
		</Style>
		<Style Selector="Button.DatabaseQuickPick">
			<Setter Property="HorizontalAlignment" Value="Stretch" />
			<Setter Property="HorizontalContentAlignment" Value="Left" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="BorderThickness" Value="0" />
			<Setter Property="Padding" Value="12 8" />
		</Style>
		<Style Selector="Button.DatabaseQuickPick:pointerover">
			<Setter Property="Background" Value="{DynamicResource ButtonBackgroundPointerOver}" />
		</Style>
	</Window.Styles>

	<SplitView IsPaneOpen="{Binding IsPaneOpen}"
		   CompactPaneLength="45"
		   DisplayMode="CompactInline"
		   OpenPaneLength="300"
		   Background="{DynamicResource SidebarBackBrush}"
		   PaneBackground="{DynamicResource SidebarBackBrush}">
		<SplitView.Pane>
			<StackPanel Orientation="Vertical"
						Spacing="5"
						HorizontalAlignment="Stretch"
						VerticalAlignment="Top">
				<Button HorizontalAlignment="Left"
						Width="32"
						Height="32"
						Margin="7 12"
						Background="Transparent"
						Command="{Binding TriggerPaneCommand}">
					<mi:MaterialIcon Kind="Menu" />
				</Button>

				<StackPanel Classes="SideBarMenu">
					<Border Classes="SideBarMenuItem">
						<StackPanel>
							<mi:MaterialIcon Kind="Home" />
							<TextBlock Text="Главная" />
						</StackPanel>

						<Interaction.Behaviors>
							<EventTriggerBehavior EventName="Tapped">
								<InvokeCommandAction Command="{Binding SwitchToCommand}"
													 CommandParameter="{x:Static services:MainPanel.Transactions}"/>
							</EventTriggerBehavior>
						</Interaction.Behaviors>

						<Border.IsEnabled>
							<Binding Path="CurrentPanel"
									 Converter="{StaticResource isNotEqualToConverter}"
									 ConverterParameter="{x:Static services:MainPanel.Transactions}" />
						</Border.IsEnabled>
					</Border>

					<Border Classes="SideBarMenuItem">
						<StackPanel>
							<mi:MaterialIcon Kind="Database" />
							<TextBlock Text="Базы данных" />
						</StackPanel>

						<Interaction.Behaviors>
							<EventTriggerBehavior EventName="Tapped">
								<InvokeCommandAction Command="{Binding TriggerPaneCommand}"/>
							</EventTriggerBehavior>
						</Interaction.Behaviors>
					</Border>

					<ItemsControl Margin="42 0 4 0" ItemsSource="{Binding Settings.Databases}"
						IsVisible="{Binding IsPaneOpen}">
						<ItemsControl.ItemsPanel>
							<ItemsPanelTemplate>
								<StackPanel Orientation="Vertical" />
							</ItemsPanelTemplate>
						</ItemsControl.ItemsPanel>
						<ItemsControl.ItemTemplate>
							<DataTemplate x:DataType="settingsVm:DatabaseViewModel">
								<Button Classes="DatabaseQuickPick"
										Command="{Binding $parent[Window].((vm:MainViewModel)DataContext).Settings.SwitchToDatabaseCommand}"
										CommandParameter="{Binding}"
										IsEnabled="{Binding !IsSelected}">
									<StackPanel Orientation="Horizontal" Spacing="8">
										<mi:MaterialIcon Kind="Check"
																			IsVisible="{Binding IsSelected}"
																			Width="14" />
										<TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
									</StackPanel>
								</Button>
							</DataTemplate>
						</ItemsControl.ItemTemplate>
					</ItemsControl>

					<Border Classes="SideBarMenuItem">
						<StackPanel>
							<mi:MaterialIcon Kind="Bookmark" />
							<TextBlock Text="Категории" />
						</StackPanel>

						<Interaction.Behaviors>
							<EventTriggerBehavior EventName="Tapped">
								<InvokeCommandAction Command="{Binding SwitchToCommand}"
													 CommandParameter="{x:Static services:MainPanel.Categories}"/>
							</EventTriggerBehavior>
						</Interaction.Behaviors>

						<Border.IsEnabled>
							<Binding Path="CurrentPanel"
									 Converter="{StaticResource isNotEqualToConverter}"
									 ConverterParameter="{x:Static services:MainPanel.Categories}" />
						</Border.IsEnabled>
					</Border>

					<Border Classes="SideBarMenuItem">
						<StackPanel>
							<mi:MaterialIcon Kind="Cog" />
							<TextBlock Text="Параметры" />
						</StackPanel>

						<Interaction.Behaviors>
							<EventTriggerBehavior EventName="Tapped">
								<InvokeCommandAction Command="{Binding SwitchToCommand}"
													 CommandParameter="{x:Static services:MainPanel.Settings}"/>
							</EventTriggerBehavior>
						</Interaction.Behaviors>

						<Border.IsEnabled>
							<Binding Path="CurrentPanel"
									 Converter="{StaticResource isNotEqualToConverter}"
									 ConverterParameter="{x:Static services:MainPanel.Settings}" />
						</Border.IsEnabled>
					</Border>

				</StackPanel>
			</StackPanel>
		</SplitView.Pane>

		<SplitView.Content>
			<Grid>
				<Border Name="TransactionsPanel"
						Classes="LeftTop" 
						IsVisible="{Binding CurrentPanel, Converter={StaticResource isEqualToConverter}, ConverterParameter={x:Static services:MainPanel.Transactions}}">
					<Grid RowDefinitions="45 *">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="{Binding LeftSideWidth, Mode=TwoWay, Converter={StaticResource gridLengthConverter}}" />
							<ColumnDefinition Width="4" />
							<ColumnDefinition Width="*" />
						</Grid.ColumnDefinitions>

						<StackPanel Orientation="Horizontal" Grid.Column="2" ZIndex="10">

							<ToggleButton IsChecked="{Binding ShowTransactionsTree}" 
										  Height="30" 
										  VerticalAlignment="Center" 
										  Margin="5 0">
								<mi:MaterialIcon Kind="FormatListGroup" />
							</ToggleButton >

							<ToggleButton IsChecked="{Binding !ShowTransactionsTree}"
										  Height="30" 
										  VerticalAlignment="Center" 
										  Margin="10 0">
								<mi:MaterialIcon Kind="CalendarCheck" />
							</ToggleButton >

							<views:PeriodView DataContext="{Binding Period}" Margin="10 0 0 0" />

							<Button Classes="AddButton"
									HotKey="Alt+C"
									Command="{Binding Transactions.AddCreditCommand}">Расход</Button>

							<Button Classes="AddButton"
									HotKey="Alt+D"
									Command="{Binding Transactions.AddDebetCommand}">Доход</Button>

							<Button Classes="AddButton"
								HotKey="Alt+T"
								Command="{Binding Transactions.AddTransferCommand}">Перевод</Button>

							<Button Classes="AddButton"
									Command="{Binding Settings.SyncNowCommand}"
									IsVisible="{Binding Settings.IsSyncAvailable}"
									IsEnabled="{Binding !Settings.IsSyncing}"
									ToolTip.Tip="Синхронизировать">
								<StackPanel Orientation="Horizontal" Spacing="6">
									<mi:MaterialIcon Kind="Sync"
													 Classes.SyncSpin="{Binding Settings.IsSyncing}">
										<mi:MaterialIcon.RenderTransform>
											<RotateTransform />
										</mi:MaterialIcon.RenderTransform>
									</mi:MaterialIcon>
									<TextBlock Text="Синхронизация" VerticalAlignment="Center" />
								</StackPanel>
							</Button>

							<Button IsVisible="False"
								HotKey="Escape"
								Command="{Binding Transactions.ClearSelectionCommand}" />

						</StackPanel>
						<StackPanel Orientation="Horizontal" Grid.Column="2" HorizontalAlignment="Right">
							<ToggleButton IsChecked="{Binding Transactions.EnableMultiSelect}"
										  Height="30"
										  VerticalAlignment="Center"
										  Margin="5 0">
								<mi:MaterialIcon Kind="PlaylistCheck" />
							</ToggleButton >
						</StackPanel>

						<views:AccountsView Grid.RowSpan="2" DataContext="{Binding Accounts}" />

						<GridSplitter Grid.Column="1" Grid.Row="1" ResizeDirection="Columns"
									  Background="Transparent"/>

						<Panel IsVisible="{Binding ShowTransactionsTree}" Grid.Column="2"	Grid.Row="1">
							<views:TransactionsView DataContext="{Binding Transactions}" />
						</Panel>
						<Panel IsVisible="{Binding !ShowTransactionsTree}" Grid.Column="2"	Grid.Row="1">
							<views:TransactionsByDatesView DataContext="{Binding Transactions}" />
						</Panel>

					</Grid>

				</Border>

				<views:CategoriesView DataContext="{Binding Categories}"
					IsVisible="{Binding $parent[Window].((vm:MainViewModel)DataContext).CurrentPanel, Converter={StaticResource isEqualToConverter}, ConverterParameter={x:Static services:MainPanel.Categories}}" />

				<views:SettingsView DataContext="{Binding Settings}"
					IsVisible="{Binding $parent[Window].((vm:MainViewModel)DataContext).CurrentPanel, Converter={StaticResource isEqualToConverter}, ConverterParameter={x:Static services:MainPanel.Settings}}" />
			</Grid>
		</SplitView.Content>
	</SplitView>
</Window>
