<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:cv="using:FamilyMoney.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
		xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
		Width="600" Height="400"
		WindowStartupLocation="CenterOwner"
		ExtendClientAreaToDecorationsHint="True"
		xmlns:views="clr-namespace:FamilyMoney.Views"
		xmlns:vm="using:FamilyMoney.ViewModels"
		x:DataType="vm:AccountViewModel"		
        x:Class="FamilyMoney.Views.AccountWindow"
		Classes="Dialog"
        Title="Счёт">
	<Window.Resources>
		<cv:ByteArrayToBitmapConverter x:Key="byteArrayToBitmapConverter" />
	</Window.Resources>
<Window.Styles>
		<Style Selector="CheckBox">
			<Setter Property="Margin" Value="20 0" />
		</Style>
	</Window.Styles>
	<Grid RowDefinitions="auto auto * auto auto">
		<TextBlock Text="Группа счетов" Margin="0 10" HorizontalAlignment="Center" IsVisible="{Binding IsGroup}"/>
		<TextBlock Text="Счёт" Margin="0 10" HorizontalAlignment="Center" IsVisible="{Binding !IsGroup}"/>

		<TextBox Text="{Binding Name}" Margin="15 35 15 5" PlaceholderText="Наименование" HorizontalAlignment="Stretch"/>
		<CheckBox Grid.Row="1" IsChecked="{Binding IsNotSummable}">Не суммировать</CheckBox>
		<Image Grid.Row="2"
			Name="ImageControl"
			DragDrop.AllowDrop="True"
			Stretch="Uniform"
			Source="{Binding ImageData, Converter={StaticResource byteArrayToBitmapConverter}}"
			VerticalAlignment="Center"
			/>
		
		<mi:MaterialIcon Grid.Row="2" Kind="Image"
			Width="100" Height="100"
			 VerticalAlignment="Stretch"
			 HorizontalAlignment="Stretch"
			 IsVisible="{Binding ImageData, Converter={x:Static ObjectConverters.IsNull}}"			 
		/>

		<Button Grid.Row="3" 
				Classes="DialogButton" 
				Width="250"
				Content="Загрузить картинку из файла" 
				HorizontalAlignment="Center"
				x:Name="ChangeImageButton"
				Click="ChangeImage"
				/>

		<StackPanel
			Grid.Row="4"
			Orientation="Horizontal"
			HorizontalAlignment="Right"
			Margin="0 5 0 10"
			>
			<Button IsDefault="True" Classes="DialogButton" Content="OK" Command="{Binding OkCommand}" />
			<Button IsCancel="True" Classes="DialogButton" Content="Отмена" Command="{Binding CancelCommand}"/>
		</StackPanel>
	</Grid>
</Window>
