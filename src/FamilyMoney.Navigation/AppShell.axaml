<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:pages="using:FamilyMoney.Navigation.Pages"
             xmlns:vm="using:FamilyMoney.ViewModels"
             x:Class="FamilyMoney.Navigation.AppShell"
             x:DataType="vm:MainWindowViewModel">
  <DrawerPage x:Name="ShellDrawer">
    <DrawerPage.Drawer>
      <pages:MenuPage DataContext="{Binding}" />
    </DrawerPage.Drawer>
    <NavigationPage x:Name="ShellNavigation">
      <pages:HomePage DataContext="{Binding}" />
    </NavigationPage>
  </DrawerPage>
</UserControl>
