<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia">

  <Style Selector="TextBlock.Secondary">
    <Setter Property="Foreground" Value="{DynamicResource TextSecondaryBrush}" />
  </Style>

  <Style Selector="SelectableTextBlock.Negative, TextBlock.Negative">
    <Setter Property="Foreground" Value="{DynamicResource NegativeBrush}" />
  </Style>

  <Style Selector="SelectableTextBlock.Positive, TextBlock.Positive">
    <Setter Property="Foreground" Value="{DynamicResource PositiveBrush}" />
  </Style>

  <Style Selector="SelectableTextBlock.Debet">
    <Setter Property="Foreground" Value="{DynamicResource PositiveBrush}" />
  </Style>

  <Style Selector="Button.Accent">
    <Setter Property="Background" Value="{DynamicResource AccentBrush}" />
    <Setter Property="Foreground" Value="White" />
    <Setter Property="CornerRadius" Value="8" />
  </Style>

  <Style Selector="ListBox">
    <Setter Property="Background" Value="Transparent" />
    <Setter Property="BorderThickness" Value="0" />
  </Style>

  <Style Selector="mi|MaterialIcon.SyncSpin">
    <Setter Property="RenderTransformOrigin" Value="50%,50%" />
    <Style.Animations>
      <Animation Duration="0:0:1.2" IterationCount="Infinite">
        <KeyFrame Cue="0%">
          <Setter Property="RotateTransform.Angle" Value="0" />
        </KeyFrame>
        <KeyFrame Cue="100%">
          <Setter Property="RotateTransform.Angle" Value="360" />
        </KeyFrame>
      </Animation>
    </Style.Animations>
  </Style>
</Styles>
