<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:settingsVm="using:FamilyMoney.ViewModels.Settings"
             xmlns:vm="using:FamilyMoney.ViewModels"
             x:Class="FamilyMoney.Navigation.Pages.SettingsPage"
             x:DataType="vm:MainViewModel"
             Header="Параметры">
  <Grid RowDefinitions="auto *" Margin="8" Background="{DynamicResource MainBackBrush}">
    <StackPanel Spacing="8">
      <StackPanel Orientation="Horizontal" Spacing="8">
        <Button Content="Синхронизировать"
                Classes="Accent"
                Command="{Binding Settings.SyncNowCommand}" />
        <Button Content="Сканировать QR-код"
                Command="{Binding Settings.ImportFromQrCommand}"
                IsVisible="{Binding Settings.IsQrImportAvailable}" />
      </StackPanel>
      <TextBlock Text="{Binding Settings.SyncStatus}" TextWrapping="Wrap" />
      <TextBlock Text="Базы данных" FontWeight="SemiBold" />
    </StackPanel>
    <ListBox Grid.Row="1" ItemsSource="{Binding Settings.Databases}" Margin="0 8 0 0">
      <ListBox.ItemTemplate>
        <DataTemplate x:DataType="settingsVm:DatabaseViewModel">
          <StackPanel Spacing="2" Margin="4">
            <TextBlock Text="{Binding Name}" FontWeight="SemiBold" />
            <TextBlock Text="{Binding Path}" Classes="Secondary" FontSize="11" />
          </StackPanel>
        </DataTemplate>
      </ListBox.ItemTemplate>
    </ListBox>
  </Grid>
</ContentPage>
