<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mi="clr-namespace:Material.Icons.Avalonia;assembly=Material.Icons.Avalonia"
             xmlns:controls="using:FamilyMoney.Navigation.Controls"
             xmlns:vm="using:FamilyMoney.ViewModels"
             x:Class="FamilyMoney.Navigation.Pages.MenuPage"
             x:DataType="vm:MainViewModel"
             Header="Меню"
             NavigationPage.HasNavigationBar="False">
  <Grid RowDefinitions="Auto Auto *">
    <StackPanel Spacing="4" Margin="8">
      <Button Click="OnSettingsClick" HorizontalAlignment="Stretch">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <mi:MaterialIcon Kind="Cog" />
          <TextBlock Text="Параметры" VerticalAlignment="Center" />
        </StackPanel>
      </Button>
    </StackPanel>

    <TextBlock Grid.Row="1"
               Text="Счета"
               FontWeight="SemiBold"
               Opacity="0.7"
               Margin="12 8 12 4" />

    <controls:AccountsDrawerView Grid.Row="2"
                                 Margin="8 0 8 8"
                                 DataContext="{Binding Accounts}" />
  </Grid>
</ContentPage>
