<ContentPage xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:FamilyMoney.ViewModels"
             x:Class="FamilyMoney.Navigation.Pages.HomePage"
             x:DataType="vm:MainViewModel"
             Header="Главная">
  <ScrollViewer>
    <StackPanel Spacing="12" Margin="16">
      <TextBlock Text="{Binding Title}" FontSize="20" FontWeight="SemiBold" />
      <TextBlock Text="Мобильная навигация на базе NavigationPage." TextWrapping="Wrap" Opacity="0.8" />
      <StackPanel Orientation="Horizontal" Spacing="8">
        <ToggleButton IsChecked="{Binding ShowTransactionsTree}" Content="Список" />
        <ToggleButton IsChecked="{Binding !ShowTransactionsTree}" Content="Даты" />
      </StackPanel>
      <Border Padding="12" CornerRadius="8" Background="{DynamicResource SystemAltMediumLowColor}">
        <StackPanel Spacing="4">
          <TextBlock Text="Счета" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Accounts.Total.Name}" />
          <TextBlock Text="{Binding Accounts.Total.Sum, StringFormat='Итого: {0:N2}'}" />
        </StackPanel>
      </Border>
      <Border Padding="12" CornerRadius="8" Background="{DynamicResource SystemAltMediumLowColor}">
        <StackPanel Spacing="4">
          <TextBlock Text="Период" FontWeight="SemiBold" />
          <TextBlock Text="{Binding Period.From, StringFormat='С {0:d}'}" />
          <TextBlock Text="{Binding Period.To, StringFormat='По {0:d}'}" />
        </StackPanel>
      </Border>
    </StackPanel>
  </ScrollViewer>
</ContentPage>
